# Base URL of the Whipperbook web REST API the mobile app talks to.
# In the simulator/emulator localhost usually works, but on a PHYSICAL DEVICE
# this MUST be the LAN IP of the machine running the web app (e.g.
# http://192.168.1.42:3000) or an `expo start --tunnel` URL — the phone cannot
# reach the host's localhost. EXPO_PUBLIC_ vars are inlined into the JS bundle.
EXPO_PUBLIC_API_URL=http://localhost:3000
