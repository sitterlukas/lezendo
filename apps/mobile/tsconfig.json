{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {},
    // Expo's base uses the legacy "node10" resolution, which ignores the
    // `exports` field that the workspace `@whipperbook/*` packages (and
    // `nativewind/types`) declare. Metro resolves bundler-style at runtime, so
    // match that here for type-checking.
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
