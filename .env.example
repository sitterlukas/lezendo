# Copy to .env.local and fill in. .env.local is gitignored.

# --- Required ---

# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/whipperbook

# Secret used to sign auth (JWT) sessions. Generate one with: npx auth secret
AUTH_SECRET=

# Vercel Blob read/write token (photo uploads). From the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# --- Google OAuth (optional) ---
# Leave both blank to disable Google sign-in (the buttons hide automatically).
# Create credentials in Google Cloud Console → Credentials → OAuth client ID
# (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (and your deployed domain)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Email verification (Resend) ---
# Sends the "verify your email" link required before credentials login. Leave
# RESEND_API_KEY blank in local dev to log the link to the console instead of
# sending. Get a key at resend.com → API Keys.
RESEND_API_KEY=
# Sender address. Defaults to Resend's sandbox sender; set to a verified domain
# in production, e.g. "Whipperbook <noreply@whipperbook.com>".
# EMAIL_FROM=

# --- Deployment only ---
# Required off-localhost (preprod/prod behind a proxy) so NextAuth builds the
# correct OAuth callback URL. Locally it's inferred and can be omitted.
# AUTH_URL=https://your-domain

# Public origin for SEO (sitemap, canonical, Open Graph) and absolute links.
# Set this in production to the canonical domain; falls back to AUTH_URL, the
# Vercel URL, then localhost. No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://www.whipperbook.com

# Separate database for integration tests (its name MUST end in _test).
# Create it once:  createdb whipperbook_test
TEST_DATABASE_URL=postgresql://localhost:5432/whipperbook_test
